{
    "name":  "@needs-two/server",
    "version":  "1.0.0",
    "private":  true,
    "type":  "module",
    "scripts":  {
                    "predev":  "npm run build -w @needs-two/shared",
                    "dev":  "tsx watch src/index.ts",
                    "build":  "tsc -p tsconfig.json",
                    "prestart":  "npm run build -w @needs-two/shared",
                    "start":  "node dist/index.js",
                    "typecheck":  "tsc -p tsconfig.json --noEmit",
                    "test":  "vitest run"
                },
    "dependencies":  {
                         "@needs-two/shared":  "*",
                         "cors":  "^2.8.5",
                         "express":  "^5.1.0",
                         "socket.io":  "^4.8.1"
                     },
    "devDependencies":  {
                            "@types/cors":  "^2.8.19",
                            "@types/express":  "^5.0.3",
                            "@types/node":  "^24.10.1",
                            "socket.io-client":  "^4.8.1",
                            "tsx":  "^4.20.6",
                            "typescript":  "^5.9.3",
                            "vitest":  "^4.0.13"
                        }
}
